pipeline {
    agent any
    environment {
        AWS_REGION = "us-east-2"
        ECR_URL = "410244537877.dkr.ecr.us-east-2.amazonaws.com"
        EKS_CLUSTER = "capitalx-prod"
    }
    stages {
        stage('Deploy to EKS') {
            steps {
                withAWS(credentials: 'aws-credentials', region: 'us-east-2') {
                    sh '''
                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}
                        
                        kubectl create namespace capitalx --dry-run=client -o yaml | kubectl apply -f -
                        
                        kubectl create secret generic capitalx-secrets -n capitalx \
                          --from-literal=DATABASE_URL="postgresql://postgres:StrongPassword123!@capitalx-postgres.cfo2kkei0x9t.us-east-2.rds.amazonaws.com:5432/capitalx_db?schema=public" \
                          --from-literal=REDIS_URL="redis://redis:6379" \
                          --from-literal=JWT_ACCESS_SECRET="capitalx_access_secret_change_me" \
                          --from-literal=JWT_REFRESH_SECRET="capitalx_refresh_secret_change_me" \
                          --dry-run=client -o yaml | kubectl apply -f -
                        
                        kubectl apply -f k8s/redis.yaml
                        kubectl apply -f k8s/backend.yml
                        kubectl apply -f k8s/frontend.yaml
                        kubectl apply -f k8s/ingress.yaml
                        
                        echo "Waiting for ALB..."
                        sleep 90
                        
                        ALB=$(kubectl get ingress capitalx-ingress -n capitalx -o jsonpath="{.status.loadBalancer.ingress[0].hostname}")
                        echo "ALB: ${ALB}"
                        
                        kubectl set env deployment/frontend -n capitalx NEXT_PUBLIC_API_URL="http://${ALB}/api/v1"
                        kubectl set env deployment/backend -n capitalx FRONTEND_URL="http://${ALB}"
                        
                        kubectl get pods -n capitalx
                        echo "Frontend: http://${ALB}/"
                        echo "Backend: http://${ALB}/api/docs"
                    '''
                }
            }
        }
    }
    post {
        success {
            emailext (
                subject: "✅ CD SUCCESS - Build #${BUILD_NUMBER}",
                mimeType: 'text/html',
                body: '<h3>Deployed to EKS!</h3>',
                to: 'aaftabparmar29@gmail.com'
            )
        }
        failure {
            emailext (
                subject: "❌ CD FAILED - Build #${BUILD_NUMBER}",
                mimeType: 'text/html',
                body: '<h3>Check logs</h3>',
                to: 'aaftabparmar29@gmail.com'
            )
        }
    }
}
