pipeline {

agent any


stages {


stage('Checkout'){

steps{

git branch: 'main',
url: 'https://github.com/aaftabparmar-DevOps-Eng/CapitalX.git'

}

}


stage('Deploy'){

steps{

sh '''

kubectl apply -f k8s/ -n capitalx

kubectl rollout restart deployment backend -n capitalx

kubectl rollout restart deployment frontend -n capitalx


'''

}

}


stage('Status'){

steps{

sh '''

kubectl get pods -n capitalx

'''

}

}


}

post {

success {

echo "Deployment Successful 🚀"

}


failure {

echo "Deployment Failed ❌"

}

}

}
